        <mxCell id="legend" value="Identifiers&#xa;E + 31 = end_to_end_id (E2EID) — original Pix, issued by originating PSP&#xa;D + 31 = rtr_id (RtrId) — devolução/refund, issued by refunding PSP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
