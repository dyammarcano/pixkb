        <mxCell id="cob" value="API Cobrança&#xa;POST /cob · /cobv&#xa;QR Code · webhook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="220" height="80" as="geometry" />
