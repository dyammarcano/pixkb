<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="BACEN-Pix-Flows">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title1" value="BACEN Pix — Payment, Devolução &amp; DICT Flows" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="700" height="30" as="geometry" />
        </mxCell>

        <mxCell id="dict" value="DICT&#xa;Diretório de Chaves&#xa;GET /entries/{Key} · claims/reivindicação" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="payer" value="Pagador PSP&#xa;(orchestration-go-pix-out)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="spi" value="SPI — BACEN&#xa;Sistema de Pagamentos Instantâneos&#xa;liquidação · reservas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="480" y="240" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="payee" value="Recebedor PSP&#xa;(orchestration-go-pix-in)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="920" y="250" width="220" height="80" as="geometry" />
