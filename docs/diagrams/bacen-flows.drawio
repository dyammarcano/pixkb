        <mxCell id="db" value="payments.pix_transactions&#xa;end_to_end_id · end_to_end_id_refund · type_transaction" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
