        <mxCell id="index" value="Postgres + pgvector&#xa;concept · embedding · edge · concept_fact&#xa;(derived, rebuildable)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
