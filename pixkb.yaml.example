# pixkb configuration example. Copy to pixkb.yaml and edit.
# Resolution order: built-in defaults < this file < PIXKB_* env vars < --dsn flag.

# Postgres DSN (a superuser must have run CREATE EXTENSION vector + btree_gist).
dsn: "postgres://pixkb:pixkb@localhost:5432/pixkb?sslmode=disable"

# Canonical OKF bundle directory (the source of truth, git-versioned).
bundle_dir: "kb"

# Drop-dir watched by `pixkb watch` for newly staged artifacts.
ingest_dir: "ingest"

# Embedder: "hashing" (pure-Go default) or "onnx" (needs `-tags onnx` + a model).
embedder: "hashing"

# Extra PDFs to ingest as ManualSection concepts (e.g. BCB manuals).
# Store operator-supplied source files in the PixKB per-user MIRROR dir, OUTSIDE
# the repo — this keeps large binaries out of git and out of the working tree.
# The PDF is NOT committed; the operator drops it there before `pixkb ingest`.
# Per-user mirror dir by OS:
#   Windows: %LocalAppData%\PixKB\mirror\   (e.g. C:\Users\<you>\AppData\Local\PixKB\mirror)
#   macOS:   ~/Library/Application Support/PixKB/mirror/
#   Linux:   ~/.config/PixKB/mirror/
# `ingest` gathers all sources and aborts if any listed file is missing, so a
# fresh checkout must place every pdfs: file first.
pdfs:
  - "C:/Users/you/AppData/Local/PixKB/mirror/pdfs/II_ManualdePadroesparaIniciacaodoPix.pdf"

# Pre-staged git repo mirrors under mirror_dir/<name> (air-gap: cloned ahead).
mirror_dir: "mirrors"
repos:
  - { owner: "bacen", name: "pix-api" }
  - { owner: "bacen", name: "pix-dict-api" }


# Standalone OpenAPI/Swagger specs (outside the repo mirrors), each tagged with a
# KB domain. Place the spec file under the per-user mirror dir (see pdfs: note).
# The Receita Federal consumption-tax calculator's spec is at
# https://consumo.tributos.gov.br/servico/calcular-tributos-consumo/api/api-docs
# (also inside the offline calculadora distribution). domain must be pix or tax.
openapi_specs:
  - { file: "C:/Users/you/AppData/Local/PixKB/mirror/openapi/tributos-consumo.json", domain: tax }
